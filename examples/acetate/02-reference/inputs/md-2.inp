&GLOBAL
  PROJECT_NAME md
  PRINT_LEVEL LOW
  RUN_TYPE MD
  WALLTIME 03:50:00
&END GLOBAL
&MOTION
  &MD
    TEMPERATURE 300.0
    TIMESTEP [fs] 0.5
    STEPS 1
    ENSEMBLE NVT
    &THERMOSTAT
      REGION GLOBAL
      TYPE CSVR
      &CSVR
        TIMECON [fs] 100
      &END CSVR
    &END THERMOSTAT
  &END MD
  &PRINT
    &TRAJECTORY
      FORMAT XYZ
      &EACH
        MD 100
      &END EACH
    &END TRAJECTORY
  &END PRINT
&END MOTION
&FORCE_EVAL
  METHOD QS
  &SUBSYS
    &TOPOLOGY
      COORD_FILE_NAME pos.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY
    &CELL
      ABC [angstrom] 15.748000144958496 15.748000144958496 15.748000144958496
      PERIODIC XYZ
    &END CELL
  &END SUBSYS
  &DFT
    &SCF
      MAX_SCF 50
      EPS_SCF 1e-06
      &OUTER_SCF
        MAX_SCF 200
        EPS_SCF 1e-06
      &END OUTER_SCF
      &OT
        PRECONDITIONER FULL_SINGLE_INVERSE
        MINIMIZER DIIS
      &END OT
      SCF_GUESS ATOMIC
    &END SCF
    &QS
      METHOD XTB
      &XTB
        CHECK_ATOMIC_CHARGES .FALSE.
        DO_EWALD .TRUE.
        USE_HALOGEN_CORRECTION .TRUE.
      &END XTB
    &END QS
    CHARGE 1
    MULTIPLICITY 1
    UKS .FALSE.
  &END DFT
&END FORCE_EVAL
