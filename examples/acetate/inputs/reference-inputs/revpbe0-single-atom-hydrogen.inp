&GLOBAL
  PROJECT_NAME H_vacuum
  PRINT_LEVEL LOW
  RUN_TYPE ENERGY
  PREFERRED_FFT_LIBRARY FFTW
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &SUBSYS
    &TOPOLOGY
      COORD_FILE_NAME pos.xyz
      COORD_FILE_FORMAT XYZ
    &END TOPOLOGY
    &CELL
      ABC [angstrom] 10.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &KIND H
      BASIS_SET TZV2P-GTH-q1
      BASIS_SET AUX_FIT cFIT3
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS

  &DFT
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    BASIS_SET_FILE_NAME BASIS_ADMM
    POTENTIAL_FILE_NAME GTH_POTENTIALS

    &SCF
      MAX_SCF 200
      EPS_SCF 1e-06
      &OT
        PRECONDITIONER FULL_SINGLE_INVERSE
        MINIMIZER DIIS
        ENERGY_GAP 0.05
      &END OT
      SCF_GUESS ATOMIC
    &END SCF

    &MGRID
      CUTOFF [Ry] 400.0
      REL_CUTOFF [Ry] 60.0
    &END MGRID

    &QS
      METHOD GPW
      EPS_DEFAULT 1e-12
    &END QS

    &AUXILIARY_DENSITY_MATRIX_METHOD
      METHOD BASIS_PROJECTION
      ADMM_PURIFICATION_METHOD MO_DIAG
      EXCH_CORRECTION_FUNC DEFAULT
    &END AUXILIARY_DENSITY_MATRIX_METHOD

    &XC
      &XC_FUNCTIONAL
        &PBE
          PARAMETRIZATION REVPBE
          SCALE_X 0.75
          SCALE_C 1.0
        &END PBE
      &END XC_FUNCTIONAL
      &HF
        FRACTION 0.25
        &SCREENING
          EPS_SCHWARZ 1.0e-6
        &END SCREENING
        &INTERACTION_POTENTIAL
          POTENTIAL_TYPE TRUNCATED
          CUTOFF_RADIUS [angstrom] 4.5
          T_C_G_DATA t_c_g.dat
        &END INTERACTION_POTENTIAL
        &MEMORY
          MAX_MEMORY 2000
        &END MEMORY
      &END HF
      &XC_GRID
        XC_DERIV NN50_SMOOTH
      &END XC_GRID
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          PARAMETER_FILE_NAME dftd3.dat
          REFERENCE_FUNCTIONAL revPBE
          R_CUTOFF [angstrom] 16.0
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC

    CHARGE 0
    MULTIPLICITY 2
    UKS .TRUE.
    &POISSON
      PERIODIC NONE
      PSOLVER MT
    &END POISSON
  &END DFT
&END FORCE_EVAL
